{
  "manifest_version": 3,
  "name": "Resy Booking Bot",
  "version": "1.0.0",
  "description": "Automated restaurant reservation booking assistant for Resy",
  "permissions": [
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://api.resy.com/*",
    "https://resy.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://resy.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
